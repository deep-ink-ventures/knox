---
import SectionHeading from '../ui/SectionHeading.astro';

const videos = [
  ['Intro + Galaxy', 'https://youtu.be/F3CJauQOisY'],
  ['Die Sterne da oben', 'https://youtu.be/lwCRC3jmIHc'],
  ['Disco Junge', 'https://youtu.be/nw1X_ANIHbo'],
  ['Er gehört in eine Einrichtung', 'https://youtu.be/6TLG4w3JcXQ'],
  ['Revolution', 'https://youtu.be/XJW7WJGbhFg'],
  ['Pilot', 'https://youtu.be/Yf5rLLrl2sk'],
  ['Wie sieht der denn aus', 'https://youtu.be/c1PoZpgBitM'],
  ['Die Zukunft', 'https://youtu.be/WJ28C0mwOvE'],
  ['Unser Traum', 'https://youtu.be/qbgcSipZgYE'],
  ['Galaxie', 'https://youtu.be/TAE-4YWWA9Y'],
];
---

<section id="videos" class="section" aria-labelledby="videos-heading">
  <span class="videos-planet" aria-hidden="true">
    <img
      class="planet"
      style="--float-duration: 8.5s"
      src="/assets/img/planet-ring.webp"
      width="480"
      height="480"
      alt=""
      loading="lazy"
    />
  </span>

  <div class="container">
    <SectionHeading eyebrow="Die Videos">
      <span id="videos-heading">Songs voll Wumms, Herz und Funkeln</span>
    </SectionHeading>

    <ol class="tracks" role="list">
      {
        videos.map(([title, url], index) => (
          <li data-reveal style={`--reveal-delay: ${(index % 5) * 70}ms`}>
            <a class="track" href={url} target="_blank" rel="noopener">
              <span class="track-num" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <span class="track-title">„{title}“</span>
              <span class="track-bars" aria-hidden="true">
                <i /><i /><i /><i /><i />
              </span>
              <span class="track-go" aria-hidden="true">↗</span>
              <span class="sr-only">– Video bei YouTube ansehen (öffnet in neuem Tab)</span>
            </a>
          </li>
        ))
      }
    </ol>

    <p class="videos-note" data-reveal>
      Alle Videos öffnen bei YouTube in einem neuen Tab. Demoaufnahmen und Noten gern
      <a href="#kontakt">auf Anfrage</a>.
    </p>
  </div>
</section>

<style>
  .videos-planet {
    position: absolute;
    top: clamp(2rem, 6vw, 5rem);
    right: 4%;
    width: clamp(80px, 12vw, 170px);
  }

  .tracks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(2rem, 4vw, 4rem);
  }

  .tracks li {
    border-bottom: 1px solid var(--line);
  }

  /* Raster füllt zeilenweise: die ersten beiden Einträge bilden die oberste Zeile */
  .tracks li:nth-child(-n + 2) {
    border-top: 1px solid var(--line);
  }

  .track {
    display: flex;
    align-items: baseline;
    gap: 1.2rem;
    padding: 1.25rem 0.5rem;
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-out);
  }

  .track:hover {
    background: rgba(127, 220, 242, 0.05);
  }

  .track-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.3rem, 1.1rem + 1vw, 1.9rem);
    color: transparent;
    -webkit-text-stroke: 1px var(--line-strong);
    min-width: 2.2ch;
  }

  .track-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(0.95rem, 0.85rem + 0.5vw, 1.15rem);
    color: var(--ink);
  }

  .track-go {
    color: var(--cyan);
    font-size: 1rem;
    opacity: 0;
    translate: -4px 2px;
    transition:
      opacity var(--duration-fast) var(--ease-out),
      translate var(--duration-fast) var(--ease-out);
  }

  .track:hover .track-go,
  .track:focus-visible .track-go {
    opacity: 1;
    translate: 0 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  /* Equalizer-Balken, animieren beim Hover über der Zeile */
  .track-bars {
    margin-left: auto;
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 1.1rem;
  }

  .track-bars i {
    width: 3px;
    height: 100%;
    background: var(--cyan);
    opacity: 0.35;
    transform: scaleY(0.25);
    transform-origin: bottom;
    transition:
      transform var(--duration) var(--ease-out),
      opacity var(--duration) var(--ease-out);
  }

  @keyframes equalize {
    from {
      transform: scaleY(0.2);
    }
    to {
      transform: scaleY(1);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .track:hover .track-bars i {
      opacity: 0.9;
      animation: equalize 0.5s ease-in-out infinite alternate;
    }

    .track:hover .track-bars i:nth-child(2n) {
      animation-duration: 0.34s;
    }

    .track:hover .track-bars i:nth-child(3n) {
      animation-duration: 0.62s;
    }
  }

  .videos-note {
    margin-top: 2.4rem;
    font-size: 0.92rem;
    color: var(--ink-faint);
  }

  @media (max-width: 880px) {
    .tracks {
      grid-template-columns: 1fr;
    }

    .tracks li:nth-child(2) {
      border-top: none;
    }

    .videos-planet {
      top: 1rem;
      width: 72px;
    }
  }
</style>
