---
import SectionHeading from '../ui/SectionHeading.astro';

/* Vorschaubilder liegen selbst gehostet unter public/assets/img/videos/ —
   beim Seitenaufruf fließen keine Daten an YouTube/Google (siehe Datenschutzerklärung). */
const videos = [
  { title: 'Intro + Galaxy', url: 'https://youtu.be/F3CJauQOisY', slug: 'intro-galaxy' },
  { title: 'Die Sterne da oben', url: 'https://youtu.be/lwCRC3jmIHc', slug: 'die-sterne-da-oben' },
  { title: 'Disco Junge', url: 'https://youtu.be/nw1X_ANIHbo', slug: 'disco-junge' },
  { title: 'Er gehört in eine Einrichtung', url: 'https://youtu.be/6TLG4w3JcXQ', slug: 'er-gehoert-in-eine-einrichtung' },
  { title: 'Revolution', url: 'https://youtu.be/XJW7WJGbhFg', slug: 'revolution' },
  { title: 'Pilot', url: 'https://youtu.be/Yf5rLLrl2sk', slug: 'pilot' },
  { title: 'Wie sieht der denn aus', url: 'https://youtu.be/c1PoZpgBitM', slug: 'wie-sieht-der-denn-aus' },
  { title: 'Die Zukunft', url: 'https://youtu.be/WJ28C0mwOvE', slug: 'die-zukunft' },
  { title: 'Unser Traum', url: 'https://youtu.be/qbgcSipZgYE', slug: 'unser-traum' },
  { title: 'Galaxie', url: 'https://youtu.be/TAE-4YWWA9Y', slug: 'galaxie' },
];
---

<section id="videos" class="section" aria-labelledby="videos-heading">
  <span class="videos-planet" aria-hidden="true">
    <img
      class="planet"
      style="--float-duration: 8.5s"
      src="/assets/img/planet-ring.webp"
      width="480"
      height="480"
      alt=""
      loading="lazy"
    />
  </span>

  <div class="container">
    <SectionHeading eyebrow="Die Videos">
      <span id="videos-heading">Songs voll Wumms, Herz und Funkeln</span>
    </SectionHeading>

    <ul class="video-grid" role="list">
      {
        videos.map(({ title, url, slug }, index) => (
          <li data-reveal style={`--reveal-delay: ${(index % 5) * 70}ms`}>
            <a
              class="video-card panel"
              href={url}
              target="_blank"
              rel="noopener"
              aria-label={`„${title}“ bei YouTube ansehen (öffnet in neuem Tab)`}
            >
              <span class="video-thumb">
                <img src={`/assets/img/videos/${slug}.webp`} width="640" height="360" alt="" loading="lazy" />
                <span class="video-play" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18">
                    <path d="M8 5.5 L18.5 12 L8 18.5 Z" fill="currentColor" />
                  </svg>
                </span>
              </span>
              <span class="video-caption">
                <span class="video-num" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
                <span class="video-title">{title}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <p class="videos-note" data-reveal>
      Alle Videos öffnen bei YouTube in einem neuen Tab. Demoaufnahmen und Noten gern
      <a href="#kontakt">auf Anfrage</a>.
    </p>
  </div>
</section>

<style>
  .videos-planet {
    position: absolute;
    top: clamp(2rem, 6vw, 5rem);
    right: 4%;
    width: clamp(80px, 12vw, 170px);
  }

  .video-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }

  @media (min-width: 520px) {
    .video-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1080px) {
    .video-grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  .video-card {
    display: block;
    overflow: clip;
    text-decoration: none;
    transition:
      transform var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out);
  }

  .video-card:hover,
  .video-card:focus-visible {
    transform: translateY(-5px);
    border-color: var(--line-strong);
    box-shadow: 0 16px 44px -18px rgba(127, 220, 242, 0.35);
  }

  .video-thumb {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: clip;
  }

  .video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .video-card:hover .video-thumb img {
    transform: scale(1.05);
  }

  .video-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: var(--cyan-bright);
  }

  .video-play svg {
    box-sizing: content-box;
    padding: 0.7em;
    border-radius: 50%;
    background: rgba(4, 7, 15, 0.62);
    border: 1px solid var(--line-strong);
    transition:
      transform var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out);
  }

  .video-card:hover .video-play svg {
    transform: scale(1.12);
    background: rgba(4, 7, 15, 0.8);
  }

  .video-caption {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.85rem 1rem;
  }

  .video-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    color: transparent;
    -webkit-text-stroke: 1px var(--line-strong);
  }

  .video-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.82rem;
    line-height: 1.35;
    color: var(--ink);
  }

  .videos-note {
    margin-top: 2.4rem;
    font-size: 0.92rem;
    color: var(--ink-faint);
  }

  @media (max-width: 880px) {
    .videos-planet {
      top: 1rem;
      width: 72px;
    }
  }
</style>
