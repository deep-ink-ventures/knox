---
import SectionHeading from '../ui/SectionHeading.astro';

/* Bis echte Bühnenfotos vorliegen: Artwork-Galerie aus der Welt von KNOX. */
const artworks = [
  ['planet-hex', 'Illustration einer kugelförmigen Raumstation mit goldenen Sechsecken'],
  ['planet-ring', 'Illustration einer ringförmigen Raumstation im All'],
  ['planet-spiral', 'Illustration einer spiralförmigen Raumstation im All'],
  ['planet-earth', 'Illustration der Erde aus dem Weltraum'],
];
---

<section id="fotos" class="section" aria-labelledby="fotos-heading">
  <div class="container">
    <SectionHeading eyebrow="Fotos">
      <span id="fotos-heading">Aus der Welt von KNOX</span>
    </SectionHeading>

    <p class="fotos-lead" data-reveal>
      Bühnenfotos der Workshop-Präsentation folgen in Kürze – bis dahin ein Blick in Schnaizers
      Galaxy.
    </p>

    <ul class="fotos-grid" role="list">
      {
        artworks.map(([name, alt], index) => (
          <li class="foto panel" data-reveal style={`--reveal-delay: ${index * 80}ms`}>
            <img src={`/assets/img/${name}.webp`} width="480" height="480" alt={alt} loading="lazy" />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .fotos-lead {
    max-width: 52ch;
    color: var(--ink-dim);
    margin-bottom: 2.4rem;
  }

  .fotos-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .foto {
    overflow: clip;
    transition:
      transform var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out);
  }

  .foto:hover {
    transform: translateY(-5px);
    border-color: var(--line-strong);
  }

  .foto img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .foto:hover img {
    transform: scale(1.045);
  }

  @media (max-width: 720px) {
    .fotos-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
