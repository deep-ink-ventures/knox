---
import SectionHeading from '../ui/SectionHeading.astro';

/* Standbilder aus den Song-Videos der Workshop-Präsentation,
   selbst gehostet unter public/assets/img/videos/. */
const stills = [
  ['intro-galaxy', 'Intro + Galaxy'],
  ['die-sterne-da-oben', 'Die Sterne da oben'],
  ['disco-junge', 'Disco Junge'],
  ['er-gehoert-in-eine-einrichtung', 'Er gehört in eine Einrichtung'],
  ['revolution', 'Revolution'],
  ['pilot', 'Pilot'],
  ['wie-sieht-der-denn-aus', 'Wie sieht der denn aus'],
  ['die-zukunft', 'Die Zukunft'],
  ['unser-traum', 'Unser Traum'],
  ['galaxie', 'Galaxie'],
];
---

<section id="fotos" class="section" aria-labelledby="fotos-heading">
  <div class="container">
    <SectionHeading eyebrow="Fotos">
      <span id="fotos-heading">Aus der Welt von KNOX</span>
    </SectionHeading>

    <p class="fotos-lead" data-reveal>
      Eindrücke von der Workshop-Präsentation am 24. Januar 2026 im eti Berlin – Standbilder aus
      den Song-Videos.
    </p>

    <ul class="fotos-grid" role="list">
      {
        stills.map(([slug, title], index) => (
          <li class="foto panel" data-reveal style={`--reveal-delay: ${(index % 2) * 90}ms`}>
            <img
              src={`/assets/img/videos/${slug}.webp`}
              width="640"
              height="360"
              alt={`Szene aus der Workshop-Präsentation: „${title}“`}
              loading="lazy"
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .fotos-lead {
    max-width: 52ch;
    color: var(--ink-dim);
    margin-bottom: 2.4rem;
  }

  .fotos-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }

  @media (min-width: 560px) {
    .fotos-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .foto {
    overflow: clip;
  }

  .foto img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .foto:hover img {
    transform: scale(1.035);
  }
</style>
