---
/* Marginales Figuren-Zitat „an der Seite" einer Sektion.
   Zitattext kommt als Slot (erlaubt <em> o. ä.), Akzentfarbe pro Figur. */
interface Props {
  attribution: string;
  accent?: string;
  align?: 'left' | 'right';
}

const { attribution, accent = 'var(--cyan)', align = 'right' } = Astro.props;
---

<figure class:list={['side-quote', `align-${align}`]} style={`--accent: ${accent}`} data-reveal>
  <blockquote>
    <p><slot /></p>
  </blockquote>
  <figcaption>{attribution}</figcaption>
</figure>

<style>
  .side-quote {
    max-width: min(30ch, 100%);
    padding-block: 0.1rem;
    margin-block: clamp(2rem, 1.5rem + 2vw, 3rem);
  }

  .align-right {
    margin-inline-start: auto;
    border-inline-end: 2px solid var(--accent);
    padding-inline-end: 1.5rem;
  }

  .align-left {
    margin-inline-end: auto;
    border-inline-start: 2px solid var(--accent);
    padding-inline-start: 1.5rem;
  }

  blockquote p {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.15rem, 0.95rem + 1vw, 1.65rem);
    line-height: 1.28;
    color: var(--ink);
  }

  /* Slotted-Markup wird vom Eltern-Scope gestylt → :global nötig */
  blockquote :global(em) {
    color: var(--accent);
    font-style: normal;
  }

  figcaption {
    margin-top: 0.85rem;
    font-family: var(--font-label);
    font-size: 0.64rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--accent);
  }
</style>
