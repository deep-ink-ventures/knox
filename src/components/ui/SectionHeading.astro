---
interface Props {
  eyebrow: string;
  align?: 'start' | 'center';
}

const { eyebrow, align = 'start' } = Astro.props;
---

<header class:list={['section-heading', align]} data-reveal>
  <p class="eyebrow">{eyebrow}</p>
  <h2><slot /></h2>
</header>

<style>
  .section-heading {
    display: grid;
    gap: 1.1rem;
    max-width: 46rem;
    margin-bottom: clamp(2.5rem, 2rem + 3vw, 4.5rem);
  }

  .section-heading.center {
    margin-inline: auto;
    text-align: center;
    justify-items: center;
  }

  .eyebrow::before {
    content: '✦';
    margin-right: 0.9em;
    color: var(--amber);
  }
</style>
