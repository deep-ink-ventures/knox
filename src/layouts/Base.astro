---
import '@fontsource/michroma';
import '@fontsource/sora/400.css';
import '@fontsource/sora/600.css';
import '@fontsource/unbounded/700.css';
import '@fontsource/unbounded/800.css';
import '../styles/tokens.css';
import '../styles/global.css';
import Starfield from '../components/Starfield.astro';

interface Props {
  title?: string;
  description?: string;
  preloadHero?: boolean;
}

const SITE_URL = 'https://knox-das-musical.de';

const {
  title = 'KNOX – Das Weltraum-Musical',
  description = 'Humorvoll und herzergreifend: KNOX, das Weltraum-Musical von Eva Strasser (Buch & Lyrics) und Stephen Sundberg (Musik). Workshop-Präsentation im Januar 2026 in Berlin – Material für Produzent:innen auf Anfrage.',
  preloadHero = false,
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, SITE_URL).href} />
    <meta name="theme-color" content="#04070f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {
      preloadHero && (
        <>
          <link rel="preload" as="image" href="/assets/img/hero-bg-800.webp" media="(max-width: 720px)" fetchpriority="high" />
          <link rel="preload" as="image" href="/assets/img/hero-bg.webp" media="(min-width: 721px)" fetchpriority="high" />
        </>
      )
    }
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE_URL}/assets/img/og.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Zum Inhalt springen</a>
    <Starfield />
    <slot />
    <script>
      const revealables = document.querySelectorAll('[data-reveal]');
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        revealables.forEach((el) => el.classList.add('is-revealed'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -36px 0px' }
        );
        revealables.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
