---
import Base from '../layouts/Base.astro';
import Hero from '../components/hero/Hero.astro';
import Videos from '../components/sections/Videos.astro';
import Story from '../components/sections/Story.astro';
import Characters from '../components/sections/Characters.astro';
import Workshop from '../components/sections/Workshop.astro';
import Team from '../components/sections/Team.astro';
import Fotos from '../components/sections/Fotos.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Base preloadHero={true}>
  <main id="main">
    <Hero />
    <Videos />
    <Story />
    <Characters />
    <Workshop />
    <Team />
    <Fotos />
    <Contact />
  </main>
  <Footer />
</Base>
